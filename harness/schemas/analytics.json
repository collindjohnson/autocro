{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "analytics.json",
  "description": "Normalized shapes for analytics adapter capabilities. Mirrors adapters/README.md:142-168 (normalized return shapes, analytics section). The validator (harness/validate.py) selects $defs.<capability> for the capability being checked. `additionalProperties: false` is intentional: stray keys from an adapter (e.g. `page` instead of `path`) must fail loudly at setup time, not silently corrupt hypothesis generation.",

  "$defs": {

    "top_pages": {
      "description": "Return of top_pages(window, limit). Array of page-level aggregates.",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "sessions", "bounce_rate", "conv_rate"],
        "additionalProperties": false,
        "properties": {
          "path":        { "type": "string", "minLength": 1 },
          "sessions":    { "type": "integer", "minimum": 0 },
          "bounce_rate": { "type": "number",  "minimum": 0, "maximum": 1 },
          "conv_rate":   { "type": "number",  "minimum": 0, "maximum": 1 },
          "avg_time_s":  { "type": "number",  "minimum": 0 }
        }
      }
    },

    "landing_pages": {
      "description": "Return of landing_pages(window, limit). Array keyed on landing path.",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "landings", "bounce_rate", "conv_rate"],
        "additionalProperties": false,
        "properties": {
          "path":        { "type": "string",  "minLength": 1 },
          "landings":    { "type": "integer", "minimum": 0 },
          "bounce_rate": { "type": "number",  "minimum": 0, "maximum": 1 },
          "conv_rate":   { "type": "number",  "minimum": 0, "maximum": 1 }
        }
      }
    },

    "funnel": {
      "description": "Return of funnel(steps). Array of funnel stages in order.",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["step", "entered", "advanced"],
        "additionalProperties": false,
        "properties": {
          "step":     { "type": "string",  "minLength": 1 },
          "entered":  { "type": "integer", "minimum": 0 },
          "advanced": { "type": "integer", "minimum": 0 }
        }
      }
    },

    "traffic_sources": {
      "description": "Return of traffic_sources(window, limit). Array of source/medium aggregates.",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source", "medium", "sessions", "conv_rate"],
        "additionalProperties": false,
        "properties": {
          "source":    { "type": "string",  "minLength": 1 },
          "medium":    { "type": "string",  "minLength": 1 },
          "sessions":  { "type": "integer", "minimum": 0 },
          "conv_rate": { "type": "number",  "minimum": 0, "maximum": 1 }
        }
      }
    },

    "conversions": {
      "description": "Return of conversions(event, window). Single-object aggregate for one event.",
      "type": "object",
      "required": ["event", "count", "sessions", "rate"],
      "additionalProperties": false,
      "properties": {
        "event":    { "type": "string",  "minLength": 1 },
        "count":    { "type": "integer", "minimum": 0 },
        "sessions": { "type": "integer", "minimum": 0 },
        "rate":     { "type": "number",  "minimum": 0, "maximum": 1 }
      }
    },

    "session_quality": {
      "description": "Return of session_quality(path, window). Single-object quality metrics for one page.",
      "type": "object",
      "required": ["path", "avg_time_s", "scroll_depth_p50", "bounce_rate", "engagement_score"],
      "additionalProperties": false,
      "properties": {
        "path":             { "type": "string", "minLength": 1 },
        "avg_time_s":       { "type": "number", "minimum": 0 },
        "scroll_depth_p50": { "type": "number", "minimum": 0, "maximum": 1 },
        "bounce_rate":      { "type": "number", "minimum": 0, "maximum": 1 },
        "engagement_score": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    }

  }
}
